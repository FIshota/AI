# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ai-chan 環境変数テンプレート
# このファイルを .env にコピーして実際の値を設定してください
# .env は .gitignore に追加されており、コミットされません
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Web API セキュリティ ──────────────────────────────
# CORS 許可オリジン（カンマ区切り）
# ローカル開発: http://localhost:8080,http://192.168.1.x:8080
# 本番LAN: http://192.168.1.0/24 相当のIPをリストアップ
AICHAN_ALLOWED_ORIGINS=http://localhost,http://localhost:8080,http://127.0.0.1:8080

# ── LLM 設定 ─────────────────────────────────────────
# Llama モデルのパス（GGUF形式）
AICHAN_MODEL_PATH=/path/to/your/model.gguf

# ── Google カレンダー ─────────────────────────────────
# credentials.json のパス（OAuth 2.0）
GOOGLE_CREDENTIALS_PATH=~/.config/ai-chan/google_credentials.json

# ── Notion 連携 ──────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# ── ログ設定 ─────────────────────────────────────────
AICHAN_LOG_LEVEL=INFO
